{
  "version": 2,
  "framework": null,
  "builds": [
    { "src": "api/index.php", "use": "vercel-php@0.7.4" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(css|js|images|fonts|branding|build)/(.*)", "dest": "/public/$1/$2" },
    { "src": "/(.*)\\.(.*)", "dest": "/public/$1.$2" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "outputDirectory": "public"
}
