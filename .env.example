APP_NAME="Life Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production: set LOG_STACK=daily and LOG_DAILY_DAYS=14
# LOG_STACK=daily
# LOG_DAILY_DAYS=14

# Force HTTPS redirects in non-local environments (set false behind trusted proxy that already terminates TLS)
APP_FORCE_HTTPS=true

ERROR_TRACKING_ENABLED=false
ERROR_TRACKING_DRIVER=log
ERROR_TRACKING_PROVIDER=custom
ERROR_TRACKING_WEBHOOK_URL=
ERROR_TRACKING_TIMEOUT=3
ERROR_TRACKING_SAMPLE_RATE=1
ERROR_TRACKING_IGNORE_STATUSES=404,419
ERROR_TRACKING_INCLUDE_TRACE=true
ERROR_TRACKING_TRACE_FRAMES=12
ERROR_TRACKING_LOG_CHANNEL="${LOG_CHANNEL}"
ERROR_TRACKING_ENVIRONMENT="${APP_ENV}"
ERROR_TRACKING_RELEASE=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lifeat
DB_USERNAME=lifeat
DB_PASSWORD=
DB_SSLMODE=prefer

# AI platform rollout switches remain off until their acceptance gates pass.
AI_EMBEDDING_PROVIDER=openai
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=
AI_KNOWLEDGE_AUTO_INDEX=true
AI_PUBLIC_CHAT_ENABLED=false
AI_PUBLIC_CHAT_ANONYMOUS_ENABLED=false
AI_PUBLIC_CHAT_HYBRID_RETRIEVAL=false
AI_PUBLIC_CHAT_STREAMING=false
AI_PUBLIC_CHAT_EMERGENCY_STOP=false
AI_PUBLIC_CHAT_RETENTION_DAYS=30
AI_EDITORIAL_DOSSIERS=false
AI_EDITORIAL_EVIDENCE_WRITER=false
AI_OPERATOR_ASSISTANT=false
AI_OPERATOR_AGENT_ENABLED=false
AI_OPERATOR_MUTATIONS=false
AI_OPERATOR_LIMITED_AUTO=false
AI_OPERATOR_STEP_LIMIT=12
AI_OPERATOR_TASK_TIMEOUT=300
AI_OPERATOR_MAX_TASK_COST=1.00

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_WORKER_ENABLED=false
QUEUE_WORKER_COMMAND="php artisan queue:work --sleep=3 --tries=3 --timeout=120"
AUTO_TRANSLATE_ON_PUBLISH=true
AUTO_TRANSLATION_QUEUE=default
AUTO_TRANSLATION_WORKER_COMMAND=
AUTO_TRANSLATION_DELAY_SECONDS=0
SCHEDULER_ENABLED=false
SCHEDULER_COMMAND="php artisan schedule:work"

# Production upload storage decision:
# - Use mounted_volume when storage/app is mounted to a durable Hetzner/Coolify volume.
# - Use s3 only after upload code paths are configured for object storage.
UPLOAD_STORAGE_BACKEND=mounted_volume
UPLOAD_STORAGE_MOUNT_PATH=/app/storage/app

CACHE_STORE=database
# CACHE_PREFIX=
LIFEAT_SETTINGS_CACHE_TTL=3600
LIFEAT_CATALOG_CACHE_TTL=1800
LIFEAT_PUBLIC_CACHE_TTL=300

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

DEV_TOOLS_ENABLED=false
DEV_TEST_RUNNER_ENABLED=false

AI_PROVIDER=openrouter
AI_TIMEOUT=90
AI_ATTEMPT_TIMEOUT=25
AI_FALLBACK_PROVIDERS=openrouter,google,openai
NVIDIA_AI_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_AI_FALLBACK_MODELS=meta/llama-3.1-70b-instruct,mistralai/mistral-nemo-12b-instruct

# Production readiness:
# - Use APP_ENV=production and APP_DEBUG=false
# - Use an https APP_URL
# - Set SESSION_SECURE_COOKIE=true
# - Use durable upload storage or a mounted volume for uploads
# - Configure a real queue worker and scheduler/cron process
# - Configure a real mail provider before launch
# - Enable PostgreSQL backups; this non-production clean reset does not require a rehearsal

BACKUPS_ENABLED=false
BACKUP_PROVIDER=
BACKUP_RETENTION_DAYS=30

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Durable public media storage. For S3-compatible object storage, set
# FILESYSTEM_DISK=public, PUBLIC_DISK_DRIVER=s3, PUBLIC_STORAGE_URL="${APP_URL}/media",
# and map the bucket credentials into the PUBLIC_AWS_* values below.
PUBLIC_DISK_DRIVER=local
PUBLIC_STORAGE_URL=
PUBLIC_AWS_ACCESS_KEY_ID=
PUBLIC_AWS_SECRET_ACCESS_KEY=
PUBLIC_AWS_DEFAULT_REGION=auto
PUBLIC_AWS_BUCKET=
PUBLIC_AWS_ENDPOINT=
PUBLIC_AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

WEBPUSH_VAPID_SUBJECT="${APP_URL}"
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=

MALL_CURRENCY=ZAR
MALL_PLATFORM_FEE_PERCENT=10
MALL_PAYFAST_MERCHANT_ID=
MALL_PAYFAST_MERCHANT_KEY=
MALL_PAYFAST_PASSPHRASE=
MALL_PAYFAST_TESTMODE=true
MALL_PAYFAST_VALIDATE_ITN_WITH_SERVER=false
MALL_PUDO_API_BASE_URL=https://api-sandbox.pudo.co.za
MALL_PUDO_API_KEY=
MALL_PUDO_AUTH_HEADER=Authorization
MALL_PUDO_AUTH_PREFIX=Bearer
MALL_PUDO_TIMEOUT=20
MALL_PUDO_DELIVERY_PLATFORM_FEE_PERCENT=0
SEED_DEMO_USERS=false
MALL_SEED_DEMO=false

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT="${PORT}"
REVERB_ALLOWED_ORIGINS="*"
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=120
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"

# ----------------------------------------------------------------------
# Backups
# ----------------------------------------------------------------------
# Local-only by default. Set BACKUP_S3_BUCKET to enable off-site upload
# to a Hetzner Storage Box, Backblaze B2, AWS S3, MinIO, etc.
# ----------------------------------------------------------------------
BACKUP_LOCAL_PATH=
BACKUP_RETENTION_DAYS=14
BACKUP_DB_ENABLED=true
BACKUP_DB_SCHEDULE="0 2 * * *"
BACKUP_MYSQLDUMP_BIN=mysqldump
BACKUP_STORAGE_ENABLED=true
BACKUP_STORAGE_SCHEDULE="0 3 * * 0"
BACKUP_STORAGE_SOURCE=
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=lifeat
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=
BACKUP_S3_PATH_STYLE=true
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_MAX_BYTES=5368709120
BACKUP_PRUNE_SCHEDULE="15 4 * * *"

# Healthchecks.io URL (optional). Format: https://hc-ping.com/<uuid>
BACKUP_HEALTHCHECK_URL=

# ----------------------------------------------------------------------
# Operator push alerts
# ----------------------------------------------------------------------
# Push channel that fires whenever an operational or business alert needs
# developer attention. See deploy/hetzner/HETZNER.md section 7.0.
# ----------------------------------------------------------------------
OPS_ALERTS_ENABLED=false
OPS_ALERT_USER_IDS=
OPS_DEV_IS_ADMIN=true
OPS_ACK_WINDOW_MINUTES=30
OPS_RETRY_AFTER_MINUTES=15
OPS_MAX_RETRIES=4
OPS_DISK_WARNING_PERCENT=80
OPS_DISK_CRITICAL_PERCENT=95
OPS_DISK_PATH=/app
OPS_QUEUE_CONNECTION=database
OPS_QUEUE_NAME=default
OPS_QUEUE_DEPTH_WARNING=500
OPS_QUEUE_DEPTH_CRITICAL=2000
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
