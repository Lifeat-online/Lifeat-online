APP_NAME="Life Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_WORKER_ENABLED=false
QUEUE_WORKER_COMMAND="php artisan queue:work --sleep=3 --tries=3 --timeout=120"
SCHEDULER_ENABLED=false
SCHEDULER_COMMAND="php artisan schedule:work"

# Production upload storage decision:
# - Use railway_volume when storage/app is mounted to a durable Railway volume.
# - Use s3 only after upload code paths are configured for object storage.
UPLOAD_STORAGE_BACKEND=
UPLOAD_STORAGE_MOUNT_PATH=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

DEV_TOOLS_ENABLED=false
DEV_TEST_RUNNER_ENABLED=false

# Production readiness:
# - Use APP_ENV=production and APP_DEBUG=false
# - Use an https APP_URL
# - Set SESSION_SECURE_COOKIE=true
# - Use durable upload storage or a Railway volume for FILESYSTEM_DISK
# - Configure a real queue worker and scheduler/cron process
# - Configure a real mail provider before launch
# - Enable database backups and complete a restore drill before accepting payments

BACKUPS_ENABLED=false
BACKUP_PROVIDER=
BACKUP_RETENTION_DAYS=30
BACKUP_RESTORE_DRILL_COMPLETED=false
BACKUP_LAST_RESTORE_DRILL_DATE=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT="${PORT}"
REVERB_ALLOWED_ORIGINS="*"
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=120
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
